{
  "version": 3,
  "name": "quantum",
  "port": 8080,
  "timeout": "5000ms",
  "output_encoding": "no-op",
  "plugin": {
    "folder": "/etc/krakend/plugins/",
    "pattern": ".so"
  },
  "endpoints": [
    {
      "endpoint": "/quantum/api",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": [
        "X-User-Token",
        "X-User",
        "X-Roles"
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "https://idp.konneqt.cloud/realms/qap-dev/protocol/openid-connect/certs",
          "jwt_header_name": "X-User-Token",
          "propagate_claims": [
            ["sub", "X-User"],
            ["realm_access.roles", "X-Roles"]
          ],
          "propagate_headers": ["Authorization"]
        }
      },
      "backend": [
        {
          "url_pattern": "/api",
          "method": "GET",
          "host": [
            "https://seu-backend-api"
          ],
          "extra_config": {
            "plugin/http-client": {
              "name": "qap-krakend-plugin",
              "gateway_name": "quantum",
              "endpoint": "/quantum/api"
            }
          }
        }
      ]
    }
  ]
}
