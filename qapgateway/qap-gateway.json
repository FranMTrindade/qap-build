{
  "version": 3,
  "name": "quantum",
  "port": 8080,
  "timeout": "5000ms",
  "output_encoding": "no-op",
  "plugin": {
    "folder": "/etc/krakend/plugins/",
    "pattern": ".so"
  },
  "endpoints": [
    {
      "endpoint": "/quantum/api",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "output_encoding": "no-op",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "https://idp.konneqt.cloud/realms/qap-dev/protocol/openid-connect/certs",
          "propagate_claims": [
            ["sub", "X-User"],
            ["realm_access.roles", "X-Roles"]
          ],
          "propagate_headers": [
            "Authorization"
          ]
        },
        "security/cors": {
          "allow_origins": ["*"],
          "allow_methods": ["GET"],
          "expose_headers": ["*"],
          "allow_headers": ["*"],
          "max_age": "12h",
          "allow_credentials": false
        },
        "proxy": {
          "sequential": true
        },
        "error": {
          "return_status_code": 400,
          "return_body": true
        }
      },
      "backend": [
        {
          "url_pattern": "/api",
          "encoding": "json",
          "sd": "static",
          "method": "GET",
          "host": [
            "https://dog.ceo"
          ],
          "extra_config": {
            "plugin/http-client": {
              "name": "qap-krakend-plugin",
              "gateway_name": "quantum",
              "endpoint": "/quantum/api"
            }
          }
        }
      ]
    }
  ]
}
